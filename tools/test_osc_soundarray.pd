#N canvas 0 0 500 450 10;
#X obj 20 250 declare -lib osc;
#X text 20 15 SoundARray OSC - 127.0.0.1:7000;
#X text 250 15 Pd 0.52+ \, [netsend -u -b];
#X text 20 45 === Single (x y z) ===;
#X obj 30 70 pack f f f 0 1.5 0;
#X obj 30 100 oscformat /spatial/source_pos -f fff;
#X obj 30 130 netsend -u -b;
#X msg 100 130 connect 127.0.0.1 7000;
#X loadbang;
#X floatatom 30 175 50 8 0 0 - - - 0;
#X floatatom 90 175 50 8 0 0 - - - 1.5;
#X floatatom 150 175 50 8 0 0 - - - 0;
#X obj 30 210 metro 50;
#X obj 200 210 toggle;
#X text 30 165 x;
#X text 90 165 y;
#X text 150 165 z;
#X text 20 245 === Multi (id x y z) id=0/1/2 ===;
#X obj 30 275 pack f f f f 0 0 1.5 0;
#X obj 30 305 oscformat /spatial/source_pos -f ffff;
#X obj 30 335 netsend -u -b;
#X msg 100 335 connect 127.0.0.1 7000;
#X floatatom 30 380 40 8 0 0 - - - 0;
#X floatatom 75 380 50 8 0 0 - - - 0;
#X floatatom 130 380 50 8 0 0 - - - 1.5;
#X floatatom 185 380 50 8 0 0 - - - 0;
#X obj 30 415 metro 50;
#X obj 200 415 toggle;
#X text 30 370 id;
#X text 75 370 x;
#X text 130 370 y;
#X text 185 370 z;
#X text 200 195 Click toggle;
#X text 200 400 Click toggle;
#X connect 8 0 7 0;
#X connect 7 0 6 0;
#X connect 7 0 20 0;
#X connect 13 0 12 0;
#X connect 12 0 4 0;
#X connect 9 0 4 1;
#X connect 10 0 4 2;
#X connect 11 0 4 3;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X connect 27 0 26 0;
#X connect 26 0 18 0;
#X connect 22 0 18 1;
#X connect 23 0 18 2;
#X connect 24 0 18 3;
#X connect 25 0 18 4;
#X connect 18 0 19 0;
#X connect 19 0 20 0;
